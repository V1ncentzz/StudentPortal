@model Announcement
@{
    ViewData["Title"] = "Post Announcement";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-megaphone"></i> Post Announcement</h1>
    <a href="/Admin/Announcements" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="CreateAnnouncement" method="post">
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input asp-for="Title" class="form-control" placeholder="Enter announcement title" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Content</label>
                <textarea asp-for="Content" class="form-control" rows="6" placeholder="Enter announcement content"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Post Announcement</button>
        </form>
    </div>
</div>
