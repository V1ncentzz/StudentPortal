@model List<Student>
@{
    ViewData["Title"] = "Manage Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-people"></i> Students</h1>
    <a href="/Admin/CreateStudent" class="btn btn-primary"><i class="bi bi-person-plus"></i> Add Student</a>
</div>

<!-- Search -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-8">
                <input type="text" name="search" class="form-control" placeholder="Search by name, email, or course..."
                       value="@ViewBag.Search" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill"><i class="bi bi-search"></i> Search</button>
                <a href="/Admin/Students" class="btn btn-outline-secondary flex-fill"><i class="bi bi-x-circle"></i> Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Course</th>
                        <th>Year</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No students found.</td></tr>
                    }
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>@s.StudentId</td>
                            <td><strong>@s.Name</strong></td>
                            <td>@s.Email</td>
                            <td><span class="badge bg-primary-subtle text-primary-emphasis">@s.Course</span></td>
                            <td>@s.YearLevel</td>
                            <td class="text-end">
                                <a href="/Admin/EditStudent/@s.StudentId" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                <a href="/Admin/DeleteStudent/@s.StudentId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if ((int)(ViewBag.TotalPages ?? 0) > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="/Admin/Students?page=@i&search=@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}
