@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-speedometer2"></i> Admin Dashboard</h1>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4 col-lg">
        <div class="stat-card bg-primary">
            <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
            <div class="stat-info">
                <h3>@ViewBag.StudentCount</h3>
                <span>Students</span>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="stat-card bg-success">
            <div class="stat-icon"><i class="bi bi-book-fill"></i></div>
            <div class="stat-info">
                <h3>@ViewBag.SubjectCount</h3>
                <span>Subjects</span>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="stat-card bg-info">
            <div class="stat-icon"><i class="bi bi-journal-check"></i></div>
            <div class="stat-info">
                <h3>@ViewBag.EnrollmentCount</h3>
                <span>Enrollments</span>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="stat-card bg-warning">
            <div class="stat-icon"><i class="bi bi-megaphone-fill"></i></div>
            <div class="stat-info">
                <h3>@ViewBag.AnnouncementCount</h3>
                <span>Announcements</span>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="stat-card bg-danger">
            <div class="stat-icon"><i class="bi bi-file-earmark-fill"></i></div>
            <div class="stat-info">
                <h3>@ViewBag.MaterialCount</h3>
                <span>Materials</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card dashboard-card">
            <div class="card-header"><i class="bi bi-lightning-fill text-warning"></i> Quick Actions</div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="/Admin/CreateStudent" class="btn btn-outline-primary"><i class="bi bi-person-plus"></i> Add New Student</a>
                    <a href="/Admin/CreateSubject" class="btn btn-outline-success"><i class="bi bi-plus-circle"></i> Add New Subject</a>
                    <a href="/Admin/CreateEnrollment" class="btn btn-outline-info"><i class="bi bi-journal-plus"></i> Enroll Student</a>
                    <a href="/Admin/CreateAnnouncement" class="btn btn-outline-warning"><i class="bi bi-megaphone"></i> Post Announcement</a>
                    <a href="/Admin/UploadMaterial" class="btn btn-outline-danger"><i class="bi bi-upload"></i> Upload Material</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card dashboard-card">
            <div class="card-header"><i class="bi bi-info-circle-fill text-info"></i> System Information</div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tr><td class="text-muted">System</td><td>Student Portal v1.0</td></tr>
                    <tr><td class="text-muted">Framework</td><td>ASP.NET Core MVC</td></tr>
                    <tr><td class="text-muted">Database</td><td>SQLite</td></tr>
                    <tr><td class="text-muted">Logged in as</td><td>@User.Identity?.Name</td></tr>
                </table>
            </div>
        </div>
    </div>
</div>
