@model Subject
@{
    ViewData["Title"] = "Add Subject";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-plus-circle"></i> Add Subject</h1>
    <a href="/Admin/Subjects" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="CreateSubject" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Subject Name</label>
                    <input asp-for="SubjectName" class="form-control" placeholder="Enter subject name" />
                    <span asp-validation-for="SubjectName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Instructor</label>
                    <input asp-for="Instructor" class="form-control" placeholder="Enter instructor name" />
                    <span asp-validation-for="Instructor" class="text-danger small"></span>
                </div>
            </div>
            <hr />
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create Subject</button>
        </form>
    </div>
</div>
