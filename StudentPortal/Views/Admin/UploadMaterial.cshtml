@{
    ViewData["Title"] = "Upload Material";
    var subjects = ViewBag.Subjects as List<Subject>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-upload"></i> Upload Material</h1>
    <a href="/Admin/Materials" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="UploadMaterial" method="post" enctype="multipart/form-data">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Subject</label>
                    <select name="subjectId" class="form-select" required>
                        <option value="">-- Select Subject --</option>
                        @if (subjects != null)
                        {
                            @foreach (var s in subjects)
                            {
                                <option value="@s.SubjectId">@s.SubjectName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">File</label>
                    <input type="file" name="file" class="form-control" required />
                </div>
            </div>
            <hr />
            <button type="submit" class="btn btn-primary"><i class="bi bi-upload"></i> Upload</button>
        </form>
    </div>
</div>
