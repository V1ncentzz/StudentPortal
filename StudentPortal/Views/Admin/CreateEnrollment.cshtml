@{
    ViewData["Title"] = "Enroll Student";
    var students = ViewBag.Students as List<Student>;
    var subjects = ViewBag.Subjects as List<Subject>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-journal-plus"></i> Enroll Student</h1>
    <a href="/Admin/Enrollments" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="CreateEnrollment" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Student</label>
                    <select name="StudentId" class="form-select" required>
                        <option value="">-- Select Student --</option>
                        @if (students != null)
                        {
                            @foreach (var s in students)
                            {
                                <option value="@s.StudentId">@s.Name (@s.Course)</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Subject</label>
                    <select name="SubjectId" class="form-select" required>
                        <option value="">-- Select Subject --</option>
                        @if (subjects != null)
                        {
                            @foreach (var s in subjects)
                            {
                                <option value="@s.SubjectId">@s.SubjectName — @s.Instructor</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <hr />
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create Enrollment</button>
        </form>
    </div>
</div>
