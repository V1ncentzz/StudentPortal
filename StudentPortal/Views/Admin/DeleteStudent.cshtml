@model Student
@{
    ViewData["Title"] = "Delete Student";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-trash"></i> Delete Student</h1>
    <a href="/Admin/Students" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card border-danger">
    <div class="card-body">
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            Are you sure you want to delete this student? This action cannot be undone.
        </div>
        <table class="table mb-4">
            <tr><th>ID</th><td>@Model.StudentId</td></tr>
            <tr><th>Name</th><td>@Model.Name</td></tr>
            <tr><th>Email</th><td>@Model.Email</td></tr>
            <tr><th>Course</th><td>@Model.Course</td></tr>
            <tr><th>Year Level</th><td>@Model.YearLevel</td></tr>
        </table>
        <form asp-action="DeleteStudent" method="post">
            <input type="hidden" name="id" value="@Model.StudentId" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Confirm Delete</button>
            <a href="/Admin/Students" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
