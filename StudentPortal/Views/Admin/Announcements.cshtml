@model List<Announcement>
@{
    ViewData["Title"] = "Manage Announcements";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-megaphone"></i> Announcements</h1>
    <a href="/Admin/CreateAnnouncement" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Post Announcement</a>
</div>

@if (Model.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-megaphone display-4"></i>
        <p class="mt-2">No announcements yet.</p>
    </div>
}

@foreach (var a in Model)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h5 class="card-title mb-1">@a.Title</h5>
                    <small class="text-muted"><i class="bi bi-calendar"></i> @a.DatePosted.ToString("MMMM dd, yyyy h:mm tt")</small>
                </div>
                <form asp-action="DeleteAnnouncement" method="post">
                    <input type="hidden" name="id" value="@a.AnnouncementId" />
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
            </div>
            <hr />
            <p class="card-text">@a.Content</p>
        </div>
    </div>
}
