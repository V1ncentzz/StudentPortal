@model Student
@{
    ViewData["Title"] = "My Profile";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><i class="bi bi-person"></i> My Profile</h1>
    <a href="/Student/EditProfile" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit Profile</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-3 text-center mb-4">
                <div class="profile-avatar">
                    <i class="bi bi-person-circle display-1 text-primary"></i>
                </div>
                <h4 class="mt-3">@Model.Name</h4>
                <span class="badge bg-primary-subtle text-primary-emphasis">@Model.Course — Year @Model.YearLevel</span>
            </div>
            <div class="col-md-9">
                <table class="table table-lg">
                    <tr><th width="200">Student ID</th><td>@Model.StudentId</td></tr>
                    <tr><th>Full Name</th><td>@Model.Name</td></tr>
                    <tr><th>Email</th><td>@Model.Email</td></tr>
                    <tr><th>Course</th><td>@Model.Course</td></tr>
                    <tr><th>Year Level</th><td>@Model.YearLevel</td></tr>
                </table>
            </div>
        </div>
    </div>
</div>
